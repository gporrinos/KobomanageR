devtools::install()
library(estatisticapesqueiraSTP)
rm(list = ls())
local_data_configuration =
readxl::read_excel(file.path("SUPORTE", "support_tables", "configuration.xlsx"),
sheet = "local_data")
local_data_directory <- local_data_configuration$local_data_directory
method               <- local_data_configuration$method
fileformat           <- local_data_configuration$fileformat
grouping_variable    <- local_data_configuration$group
if(!dir.exists(file.path(local_data_directory))) {
dir.create(local_data_directory)
}
questionnaire_information_path <- file.path("SUPORTE", "support_tables", "questionnaire_information.xlsx")
dat_information <- readxl::read_excel(questionnaire_information_path, sheet = "data")
devtools::document()
devtools::document()
devtools::check()
